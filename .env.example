# Example environment for local dev. Copy to `.env` and adjust.
# `.env` is gitignored; this example is committed.

# --- Credentials envelope (Phase 2) ---
# base64-encoded 32 bytes, SHARED by the app and the pipeline. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
CREDENTIALS_MASTER_KEY=

# Egress allowlist for the pipeline SSRF guard: hosts permitted even when they
# resolve to private/compose-internal addresses (the throwaway test servers +
# MinIO). Consumed by the pipeline service.
EGRESS_ALLOW_HOSTS=minio,sftp-test,ftp-test,ftps-test

# --- App object storage / asset service (Phase 3) ---
# The app only PRESIGNS (offline) — the endpoint must be reachable by the
# BROWSER that uses the URL. On the host, localhost:9000 works for both. Inside
# compose, set a browser-reachable host (never http://minio:9000).
# Defaults below match the compose MinIO, so these are optional locally.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=stac-higher
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true

# --- Pipeline platform storage / staging cleanup (Phase 3) ---
# The pipeline runs inside compose and reaches MinIO at http://minio:9000.
# Defaults match compose; override for a cloud deployment.
# STAGING_S3_ENDPOINT=http://minio:9000
# STAGING_S3_ACCESS_KEY_ID=minioadmin
# STAGING_S3_SECRET_ACCESS_KEY=minioadmin
# STAGING_BUCKET=stac-higher
# STAGING_TTL_SECONDS=86400
